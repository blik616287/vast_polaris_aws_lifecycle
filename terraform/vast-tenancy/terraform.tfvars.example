# Copy to terraform.tfvars once a VoC cluster + VMS endpoint exist.
vms_host            = "10.20.0.10"   # VMS VIP (routable from where TF runs)
vms_port            = 443
vms_api_token       = "REPLACE_WITH_SCOPED_MANAGER_TOKEN"
vms_skip_ssl_verify = true

tenants = {
  team-alpha = {
    client_ip_ranges = [["172.20.20.10", "172.20.20.250"]]
    vip_ip_ranges    = [["10.20.0.20", "10.20.0.40"]]
    subnet_cidr      = 16
    qos_tier         = "gold"
    storage_path     = "/k8s/team-alpha"
    nfs_read_write   = ["172.20.20.0/22"]
  }
  team-beta = {
    client_ip_ranges = [["172.20.24.10", "172.20.24.250"]]
    vip_ip_ranges    = [["10.20.0.50", "10.20.0.70"]]
    subnet_cidr      = 16
    qos_tier         = "silver"
    storage_path     = "/k8s/team-beta"
    nfs_read_write   = ["172.20.24.0/22"]
  }
}
